{
  "name": "video-player-language-learning",
  "version": "0.9.2",
  "description": "An Electron desktop video player focused on subtitle translation and language learning.",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/*.test.mjs",
    "dist:win": "electron-builder --win nsis portable",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:linux": "electron-builder --linux AppImage",
    "start:desktop": "electron .",
    "start:mobile": "npm --workspace mobile run start",
    "android": "npm --workspace mobile run android",
    "ios": "npm --workspace mobile run ios",
    "mobile:doctor": "npm --workspace mobile run doctor",
    "test:core": "node --test packages/core/test/*.test.mjs"
  },
  "dependencies": {
    "ffmpeg-static": "5.3.0",
    "@google/genai": "^2.3.0",
    "archiver": "^7.0.1"
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "26.15.6"
  },
  "build": {
    "appId": "com.videoplayer.languagelearning",
    "productName": "VideoPlayer - LanguageLearning",
    "asar": true,
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "files": [
      "electron/**/*",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.education"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "private": true,
  "workspaces": [
    "mobile",
    "packages/*"
  ]
}
