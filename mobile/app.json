{
  "expo": {
    "name": "VideoPlayer - LanguageLearning",
    "slug": "vpll-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.videoplayer.languagelearning.mobile"
    },
    "android": {
      "package": "com.videoplayer.languagelearning.mobile"
    },
    "plugins": [
      [
        "expo-file-system",
        {
          "supportsOpeningDocumentsInPlace": true,
          "enableFileSharing": true
        }
      ],
      "expo-video"
    ]
  }
}
